{
  "name": "grok-build-desktop",
  "version": "0.5.14",
  "private": true,
  "description": "Windows desktop GUI for the local Grok Build CLI",
  "main": "out/main/index.js",
  "author": "Grok Build Desktop contributors",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "npm run build:resources && npm run build && electron .",
    "dev:local": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:APP_BUILD_PROFILE='local'; npm run dev\"",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:computer-host": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-computer-host.ps1 -SelfTest",
    "build:resources": "npm run build:computer-host && node scripts/generate-resource-manifest.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:computer-acceptance": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/probe-computer-flows.ps1",
    "test:ui-acceptance": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/probe-v030-ui.ps1",
    "package:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-win.ps1",
    "package:dir": "npm run check:public && npm run build:resources && npm run build && electron-builder --win --dir --x64",
    "release:assets": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-release-assets.ps1",
    "licenses": "license-checker-rseidelsohn --production --json --out release/THIRD_PARTY_LICENSES.json",
    "check:public": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-public-safety.ps1",
    "verify": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify.ps1",
    "verify:live": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-live.ps1"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "1.2.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@monaco-editor/react": "4.7.0",
    "fflate": "0.8.3",
    "katex": "0.17.0",
    "mermaid": "11.16.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "react-virtuoso": "4.18.10",
    "rehype-katex": "7.0.1",
    "rehype-sanitize": "6.0.0",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0",
    "shiki": "4.3.1",
    "smol-toml": "1.7.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@electron/fuses": "2.1.3",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "license-checker-rseidelsohn": "5.0.1",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "overrides": {
    "dompurify": "3.4.12"
  },
  "build": {
    "appId": "io.github.grokbuilddesktop.community",
    "productName": "Grok Build Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/main/**/*",
      "out/preload/**/*",
      "out/renderer/**/*",
      "package.json",
      "app.defaults.json",
      "LICENSE",
      "CHANGELOG.md",
      "THIRD_PARTY_NOTICES.md",
      "README.md",
      "SECURITY.md"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Grok-Build-Desktop-${version}-${arch}.${ext}",
      "signExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "forceCodeSigning": false,
    "electronLanguages": [
      "zh-CN"
    ],
    "asar": true,
    "afterPack": "scripts/after-pack.cjs",
    "nsis": {
      "include": "build/installer.nsh",
      "artifactName": "Grok-Build-Desktop-Setup-v${version}-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Grok Build Desktop",
      "deleteAppDataOnUninstall": false,
      "installerLanguages": [
        "zh_CN"
      ],
      "language": "2052"
    },
    "extraResources": [
      {
        "from": "resources/native/win-x64",
        "to": "native/win-x64",
        "filter": [
          "GrokComputerHost.exe"
        ]
      },
      {
        "from": "resources/plugins/grok-computer-use",
        "to": "plugins/grok-computer-use"
      },
      {
        "from": "resources/resource-manifest.json",
        "to": "resource-manifest.json"
      }
    ]
  },
  "engines": {
    "node": ">=24 <25",
    "npm": "11.6.2"
  },
  "packageManager": "npm@11.6.2"
}
